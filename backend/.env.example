SECRET_KEY=replace-with-a-long-random-secret
JWT_SECRET_KEY=replace-with-a-different-long-random-secret
# DATABASE_URL defaults to an absolute SQLite path — safe to omit for local dev.
# For PostgreSQL on Render/Railway: DATABASE_URL=postgresql://user:pass@host/db
FLASK_ENV=production
CORS_ORIGINS=https://yourdomain.com
# Overrides the seeded admin password (only used on first run when DB is empty)
ADMIN_PASSWORD=change-this-before-deploying
